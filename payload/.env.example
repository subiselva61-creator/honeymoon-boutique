PAYLOAD_SECRET=
# Local: leave empty or use file: path. Production: Neon / Vercel Postgres connection string.
DATABASE_URI=
FRONTEND_URL=https://YOUR-FRONTEND.vercel.app
NEXT_PUBLIC_SERVER_URL=https://YOUR-PAYLOAD-PROJECT.vercel.app

# Optional LAN / alternate hosts during dev:
# PAYLOAD_ALLOWED_ORIGINS=

# Production media (UploadThing). Without it, local disk is used (dev only).
# UPLOADTHING_TOKEN=

# After schema is stable, set PAYLOAD_DATABASE_PUSH=false and use Payload migrations.
# PAYLOAD_DATABASE_PUSH=

# Must match frontend REVALIDATE_SECRET. Triggers storefront cache refresh on publish.
# REVALIDATE_SECRET=
# Optional override (default: same as storefront FRONTEND_URL):
# FRONTEND_REVALIDATE_URL=
